# SMTP Email Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@artic.live

# Admin API bearer token.
# Local emulator falls back to articadmin2026 if this is omitted, but production must set it in Secret Manager.
ADMIN_TOKEN=change_this_admin_token

# Quarterly Notion archive.
# Local live Notion fetch reads this from functions/.env.local or functions/.env.
# Production functions read NOTION_API_KEY from Firebase Secret Manager.
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_QUARTERLY_DATA_SOURCE_ID=7ae145b9-b8bb-4a0c-94c0-b804ab1c9357
